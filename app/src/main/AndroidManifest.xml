<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ================================================ -->
    <!-- 权限声明                                              -->
    <!-- ================================================ -->

    <!-- 悬浮窗权限（必须：SYSTEM_ALERT_WINDOW） -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ 录屏前台服务类型 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <!-- Android 14+ 特殊用途前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 无障碍服务绑定权限 -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />

    <!-- 相机权限（OCR 兜底方案） -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- 存储权限（Excel 导入 / Debug 截图） -->
    <!-- Android 10 (API 29) 起使用分区存储，不需要 WRITE_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />

    <!-- Android 13+ 媒体图片读取权限 -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- 网络权限 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 唤醒锁（防止录屏时 CPU 休眠） -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 查询其他应用包（Android 11+ 包可见性），仅查询必要的包 -->
    <!-- 注意：Google Play 上架需要填写声明表单，建议缩小为 <queries> 过滤 -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- ================================================ -->
    <!-- 硬件特性声明                                              -->
    <!-- ================================================ -->

    <!-- 相机（非必须，OCR 兜底方案用） -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <!-- 相机自动对焦 -->
    <uses-feature
        android:name="android.hardware.camera.autofocus"
        android:required="false" />

    <!-- ================================================ -->
    <!-- Application 入口                                      -->
    <!-- ================================================ -->

    <application
        android:name=".SearchApplication"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartSearch"
        android:requestLegacyExternalStorage="true"
        tools:targetApi="34">

        <!-- ======================================== -->
        <!-- Activity 注册                              -->
        <!-- ======================================== -->

        <!-- 主 Activity：首页 -->
        <activity
            android:name=".ui.HomeActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:theme="@style/Theme.SmartSearch">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 权限引导页 -->
        <activity
            android:name=".ui.PermissionGuideActivity"
            android:exported="false"
            android:theme="@style/Theme.SmartSearch" />

        <!-- 题库导入页 -->
        <activity
            android:name=".ui.QuestionImportActivity"
            android:exported="false"
            android:theme="@style/Theme.SmartSearch" />

        <!-- 练习页 -->
        <activity
            android:name=".ui.PracticeActivity"
            android:exported="false"
            android:theme="@style/Theme.SmartSearch" />

        <!-- 错题本页 -->
        <activity
            android:name=".ui.WrongBookActivity"
            android:exported="false"
            android:theme="@style/Theme.SmartSearch" />

        <!-- ======================================== -->
        <!-- Service 注册                               -->
        <!-- ======================================== -->

        <!-- 悬浮球前台服务 -->
        <!-- Android 14+: foregroundServiceType="specialUse" + 子类型说明 -->
        <service
            android:name=".core.service.FloatingWindowService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="floating_ball_for_search_question" />
        </service>

        <!-- 无障碍搜题服务 -->
        <!-- Android 12+: exported="true" 显式声明 -->
        <service
            android:name=".feature.search.accessibility.AccessibilitySearchService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 录屏搜题服务（前台服务） -->
        <!-- Android 14+: foregroundServiceType="mediaProjection" -->
        <service
            android:name=".feature.search.capture.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- ======================================== -->
        <!-- Provider 注册                               -->
        <!-- ======================================== -->

        <!-- FileProvider：文件共享（Excel 导入 / Debug 截图） -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>