<resources>
    <!-- ============================================ -->
    <!-- 应用基础信息                                              -->
    <!-- ============================================ -->
    <string name="app_name">智能搜题</string>
    <string name="app_description">悬浮窗搜题 · 无障碍识别 · OCR 拍照</string>

    <!-- ============================================ -->
    <!-- 无障碍服务                                              -->
    <!-- ============================================ -->
    <string name="accessibility_service_description">
        智能搜题无障碍服务，用于自动识别屏幕上的题目文字并匹配答案。
        开启后，点击悬浮球即可框选搜题区域，服务将自动提取文字并显示答案。
        本服务不会收集或上传任何个人信息。
    </string>
    <string name="accessibility_not_enabled">无障碍服务未开启</string>
    <string name="accessibility_guide">请在「设置 → 无障碍 → 智能搜题」中开启无障碍服务</string>

    <!-- ============================================ -->
    <!-- 悬浮窗提示                                              -->
