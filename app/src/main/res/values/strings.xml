    <string name="floating_window_notification_title">智能搜题运行中</string>
    <string name="floating_window_notification_text">点击悬浮球开始搜题</string>
    <string name="floating_ball_started">悬浮球已启动，点击悬浮球开始搜题</string>
    <string name="floating_window_permission_required">请先授予悬浮窗权限</string>

