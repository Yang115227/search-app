<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================ -->
    <!-- Material3 DayNight 主题                           -->
    <!-- ============================================ -->

    <!-- 基础主题（日间/夜间自动切换） -->
    <style name="Theme.SmartSearch" parent="Theme.Material3.Light.NoActionBar">
        <!-- 主色调 -->
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="colorOnPrimary">@color/answer_window_bg</item>
        <item name="colorSecondary">@color/color_accent</item>
        <item name="colorOnSecondary">@color/answer_window_bg</item>

        <!-- 背景色 -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- 状态栏 -->
        <item name="android:statusBarColor">@color/color_primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- 日间主题 -->
    <style name="Theme.SmartSearch.Light" parent="Theme.SmartSearch" />

    <!-- 夜间主题 -->
    <style name="Theme.SmartSearch.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorPrimaryVariant">@color/color_primary_dark</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:navigationBarColor">#121212</item>
    </style>
</resources>